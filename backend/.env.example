# English Coach Agent — 后端环境配置示例
# 复制为 .env 后填写。前缀 ENGLISH_COACH_。密钥绝不入库（见 .gitignore）。

# ── 服务 ─────────────────────────────────────────────
ENGLISH_COACH_HOST=127.0.0.1
ENGLISH_COACH_PORT=8000
ENGLISH_COACH_DEBUG=false

# 前端 dev server 源（CORS）。多个用 JSON 数组写法。
ENGLISH_COACH_CORS_ORIGINS=["http://localhost:5173"]

# ── 存储（LocalAdapter: SQLite，L1）──────────────────
# 相对路径基于 backend/ 目录。data/ 已在 .gitignore。
ENGLISH_COACH_DATABASE_URL=sqlite:///./data/english_coach.db

# ── LLM provider 连接信息（L1 适配器读取）──────────────
# 80% 模型走 OpenAI 兼容协议（kind=openai_compat，默认）：填 base_url + api_key 即可。
# Claude 走原生协议（kind=claude，评分用）。
# 按任务分配模型（scoring/reasoning/tokenize/conversation）在应用内 Settings 配置，
# 这里只放各 provider 的连接凭证（密钥来源）。命名约定（嵌套分隔符 __）：
#   ENGLISH_COACH_LLM_PROVIDERS__<名字>__KIND      = openai_compat | claude
#   ENGLISH_COACH_LLM_PROVIDERS__<名字>__BASE_URL  = ...
#   ENGLISH_COACH_LLM_PROVIDERS__<名字>__API_KEY   = ...
# <名字> 即 Settings.model_config 里各任务引用的 provider。
#
# Claude（原生，评分用）—— base_url 留空走官方端点
# ENGLISH_COACH_LLM_PROVIDERS__CLAUDE__KIND=claude
# ENGLISH_COACH_LLM_PROVIDERS__CLAUDE__API_KEY=sk-ant-...
#
# OpenAI 兼容（DeepSeek / Qwen / Kimi / 智谱 …）
# ENGLISH_COACH_LLM_PROVIDERS__DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
# ENGLISH_COACH_LLM_PROVIDERS__DEEPSEEK__API_KEY=sk-...
#
# 本地（Ollama / vLLM / LM Studio），无需 key
# ENGLISH_COACH_LLM_PROVIDERS__OLLAMA__BASE_URL=http://localhost:11434/v1

# ── 语音 STT / TTS（L4，ADR-012）────────────────────
# 默认走 OpenAI 兼容音频协议（kind=openai_compat）：填 base_url + api_key + model，
# 云端（OpenAI / Groq …）或本地服务（faster-whisper-server 等）皆可。命名约定同 LLM：
#   ENGLISH_COACH_STT_PROVIDERS__<名字>__KIND      = openai_compat | faster_whisper
#   ENGLISH_COACH_STT_PROVIDERS__<名字>__BASE_URL / API_KEY / MODEL
#   ENGLISH_COACH_TTS_PROVIDERS__<名字>__KIND      = openai_compat | piper
#   ENGLISH_COACH_TTS_PROVIDERS__<名字>__BASE_URL / API_KEY / MODEL / VOICE
# 多个 provider 时用 DEFAULT_STT_PROVIDER / DEFAULT_TTS_PROVIDER 指定启动默认。
#
# STT —— OpenAI 兼容（云端）
# ENGLISH_COACH_STT_PROVIDERS__OPENAI__KIND=openai_compat
# ENGLISH_COACH_STT_PROVIDERS__OPENAI__BASE_URL=https://api.openai.com/v1
# ENGLISH_COACH_STT_PROVIDERS__OPENAI__API_KEY=sk-...
# ENGLISH_COACH_STT_PROVIDERS__OPENAI__MODEL=whisper-1
#
# STT —— 纯本地离线（faster-whisper，需 pip install -e ".[voice]"；model 为尺寸 base/small/...）
# ENGLISH_COACH_STT_PROVIDERS__LOCAL__KIND=faster_whisper
# ENGLISH_COACH_STT_PROVIDERS__LOCAL__MODEL=base
#
# TTS —— OpenAI 兼容（云端）
# ENGLISH_COACH_TTS_PROVIDERS__OPENAI__KIND=openai_compat
# ENGLISH_COACH_TTS_PROVIDERS__OPENAI__BASE_URL=https://api.openai.com/v1
# ENGLISH_COACH_TTS_PROVIDERS__OPENAI__API_KEY=sk-...
# ENGLISH_COACH_TTS_PROVIDERS__OPENAI__MODEL=tts-1
# ENGLISH_COACH_TTS_PROVIDERS__OPENAI__VOICE=alloy
#
# TTS —— 纯本地离线（piper；model 为语音模型 .onnx 路径）
# ENGLISH_COACH_TTS_PROVIDERS__LOCAL__KIND=piper
# ENGLISH_COACH_TTS_PROVIDERS__LOCAL__MODEL=/path/to/en_US-amy-medium.onnx

# ── 发音评估（ADR-003 / ADR-013，默认 none）────────────────────
# 默认不接：口语发音/流利度两维空缺并标注「未接入发音评估」，不假评（ADR-013）。
# 填 Azure key 后升级为音素级真实评分（发音/流利度才有分）。
# ENGLISH_COACH_AZURE_SPEECH_KEY=
# ENGLISH_COACH_AZURE_SPEECH_REGION=
